<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>房间管理 - 出租屋租赁管理系统</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>出租屋租赁管理系统</h1>
            <div class="user-info">
                <span>欢迎, <%= username %></span>
                <a href="/logout" class="btn btn-danger">退出</a>
            </div>
        </header>

        <div class="page-header">
            <h2>房间管理</h2>
            <div>
                <button onclick="showAddRoomModal()" class="btn btn-primary">添加房间</button>
                <a href="/dashboard" class="btn btn-secondary">返回首页</a>
            </div>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>房号</th>
                    <th>月租金</th>
                    <th>电费单价</th>
                    <th>水费单价</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody id="roomsTableBody">
                <% rooms.forEach(room => { %>
                    <tr data-room-id="<%= room.id %>">
                        <td><%= room.room_number %></td>
                        <td>¥<%= room.monthly_rent.toFixed(2) %></td>
                        <td>¥<%= room.electricity_rate.toFixed(2) %>/度</td>
                        <td>¥<%= room.water_rate.toFixed(2) %>/吨</td>
                        <td>
                            <button onclick="editRoom(<%= room.id %>)" class="btn btn-small">编辑</button>
                            <a href="/rooms/<%= room.id %>" class="btn btn-small">详情</a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="modal" id="addRoomModal" style="display: none;">
            <div class="modal-content">
                <span class="close" onclick="closeAddRoomModal()">&times;</span>
                <h3>添加房间</h3>
                <form id="addRoomForm">
                    <div class="form-group">
                        <label>房号</label>
                        <input type="text" id="room_number" required>
                    </div>
                    <div class="form-group">
                        <label>月租金</label>
                        <input type="number" id="monthly_rent" step="0.01" required>
                    </div>
                    <div class="form-group">
                        <label>电费单价</label>
                        <input type="number" id="electricity_rate" step="0.01" required>
                    </div>
                    <div class="form-group">
                        <label>水费单价</label>
                        <input type="number" id="water_rate" step="0.01" required>
                    </div>
                    <button type="submit" class="btn btn-primary">保存</button>
                </form>
            </div>
        </div>

        <div class="modal" id="editRoomModal" style="display: none;">
            <div class="modal-content">
                <span class="close" onclick="closeModal()">&times;</span>
                <h3>编辑房间</h3>
                <form id="editRoomForm">
                    <input type="hidden" id="edit_room_id">
                    <div class="form-group">
                        <label>房号</label>
                        <input type="text" id="edit_room_number">
                    </div>
                    <div class="form-group">
                        <label>月租金</label>
                        <input type="number" id="edit_monthly_rent" step="0.01" required>
                    </div>
                    <div class="form-group">
                        <label>电费单价</label>
                        <input type="number" id="edit_electricity_rate" step="0.01" required>
                    </div>
                    <div class="form-group">
                        <label>水费单价</label>
                        <input type="number" id="edit_water_rate" step="0.01" required>
                    </div>
                    <button type="submit" class="btn btn-primary">保存</button>
                </form>
            </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
