<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>收据明细 - 出租屋租赁管理系统</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .receipt-container {
            max-width: 800px;
            margin: 40px auto;
            padding: 40px;
            background: white;
            border: 2px solid #333;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        .receipt-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .receipt-header h1 {
            font-size: 24px;
            margin: 0;
            color: #333;
        }

        .receipt-title {
            font-size: 18px;
            margin-top: 10px;
            color: #666;
        }

        .receipt-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            padding: 10px;
            background: #f5f5f5;
            border-radius: 5px;
        }

        .receipt-info div {
            text-align: center;
        }

        .receipt-info label {
            font-size: 12px;
            color: #666;
            display: block;
        }

        .receipt-info span {
            font-size: 14px;
            font-weight: bold;
            color: #333;
        }

        .receipt-details {
            margin: 30px 0;
        }

        .receipt-details h3 {
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
            margin-bottom: 20px;
            color: #333;
        }

        .receipt-table {
            width: 100%;
            border-collapse: collapse;
        }

        .receipt-table th,
        .receipt-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        .receipt-table th {
            background-color: #f8f8f8;
            font-weight: bold;
        }

        .receipt-table td {
            text-align: right;
        }

        .receipt-table td:first-child {
            text-align: left;
        }

        .receipt-table .total-row {
            background-color: #f0f0f0;
            font-weight: bold;
        }

        .receipt-footer {
            margin-top: 30px;
            text-align: center;
        }

        .receipt-footer p {
            margin: 10px 0;
            color: #666;
        }

        .receipt-actions {
            margin-top: 30px;
            text-align: center;
        }

        .receipt-actions a {
            display: inline-block;
            margin: 0 10px;
        }

        .status-badge {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: bold;
        }

        .status-paid {
            background-color: #28a745;
            color: white;
        }

        .status-pending {
            background-color: #ffc107;
            color: #333;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>出租屋租赁管理系统</h1>
            <div class="user-info">
                <span>欢迎, <%= username %></span>
                <a href="/logout" class="btn btn-danger">退出</a>
            </div>
        </header>

        <div class="page-header">
            <h2>收据明细</h2>
            <a href="/receipts" class="btn btn-secondary">返回收据列表</a>
            <a href="/rooms/<%= receipt.room_id %>" class="btn btn-secondary">房间详情</a>
        </div>

        <div class="receipt-container">
            <div class="receipt-header">
                <h1>出租屋租赁管理系统</h1>
                <div class="receipt-title">收款收据</div>
            </div>

            <div class="receipt-info">
                <div>
                    <label>收据编号</label>
                    <span>RECEIPT-<%= receipt.id %></span>
                </div>
                <div>
                    <label>收据日期</label>
                    <span><%= new Date().toLocaleDateString('zh-CN') %></span>
                </div>
                <div>
                    <label>状态</label>
                    <span>
                        <% if (receipt.status === 'paid') { %>
                            <span class="status-badge status-paid">已支付</span>
                        <% } else { %>
                            <span class="status-badge status-pending">未支付</span>
                        <% } %>
                    </span>
                </div>
            </div>

            <div class="receipt-info">
                <div>
                    <label>房间</label>
                    <span><%= receipt.room_number %></span>
                </div>
                <div>
                    <label>收据月份</label>
                    <span><%= receipt.receipt_month %></span>
                </div>
            </div>

            <div class="receipt-details">
                <h3>费用明细</h3>
                <table class="receipt-table">
                    <thead>
                        <tr>
                            <th>项目</th>
                            <th>数量/读数</th>
                            <th>单价</th>
                            <th>金额</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>月租金</td>
                            <td>1 个月</td>
                            <td>¥<%= receipt.monthly_rent.toFixed(2) %></td>
                            <td>¥<%= receipt.monthly_rent.toFixed(2) %></td>
                        </tr>
                        <tr>
                            <td>电费</td>
                            <td><%= receipt.electricity_consumption.toFixed(2) %> 度</td>
                            <td>¥<%= room.electricity_rate.toFixed(2) %>/度</td>
                            <td>¥<%= receipt.electricity_amount.toFixed(2) %></td>
                        </tr>
                        <tr>
                            <td>水费</td>
                            <td><%= receipt.water_consumption.toFixed(2) %> 吨</td>
                            <td>¥<%= room.water_rate.toFixed(2) %>/吨</td>
                            <td>¥<%= receipt.water_amount.toFixed(2) %></td>
                        </tr>
                        <tr>
                            <td>卫生费</td>
                            <td>1 个月</td>
                            <td>¥<%= receipt.housekeeping_fee.toFixed(2) %></td>
                            <td>¥<%= receipt.housekeeping_fee.toFixed(2) %></td>
                        </tr>
                        <tr>
                            <td>网费</td>
                            <td>1 个月</td>
                            <td>¥<%= receipt.internet_fee.toFixed(2) %></td>
                            <td>¥<%= receipt.internet_fee.toFixed(2) %></td>
                        </tr>
                        <tr class="total-row">
                            <td>总计</td>
                            <td></td>
                            <td></td>
                            <td>¥<%= receipt.total_amount.toFixed(2) %></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="receipt-details">
                <h3>电表读数</h3>
                <table class="receipt-table">
                    <thead>
                        <tr>
                            <th>项目</th>
                            <th>上月读数</th>
                            <th>本月读数</th>
                            <th>用量</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>电表</td>
                            <td><%= receipt.electricity_before ? receipt.electricity_before.toFixed(2) : '-' %></td>
                            <td><%= receipt.electricity_after ? receipt.electricity_after.toFixed(2) : '-' %></td>
                            <td><%= receipt.electricity_consumption.toFixed(2) %> 度</td>
                        </tr>
                        <tr>
                            <td>水表</td>
                            <td><%= receipt.water_before ? receipt.water_before.toFixed(2) : '-' %></td>
                            <td><%= receipt.water_after ? receipt.water_after.toFixed(2) : '-' %></td>
                            <td><%= receipt.water_consumption.toFixed(2) %> 吨</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="receipt-footer">
                <p>单位: 元 (CNY)</p>
                <p>此收据为系统自动生成，请妥善保管</p>
            </div>

            <div class="receipt-actions">
                <% if (receipt.status === 'pending') { %>
                    <button onclick="payReceipt(<%= receipt.id %>)" class="btn btn-success">标记为已支付</button>
                <% } %>
                <a href="/rooms/<%= receipt.room_id %>/receipts" class="btn btn-secondary">查看该房间所有收据</a>
                <a href="/receipts" class="btn btn-secondary">返回收据列表</a>
            </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
