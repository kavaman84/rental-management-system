<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>房间详情 - 出租屋租赁管理系统</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>出租屋租赁管理系统</h1>
            <div class="user-info">
                <span>欢迎, <%= username %></span>
                <a href="/logout" class="btn btn-danger">退出</a>
            </div>
        </header>

        <div class="page-header">
            <h2>房间详情 - <%= room.room_number %></h2>
            <a href="/rooms" class="btn btn-secondary">返回房间列表</a>
        </div>

        <div class="room-info">
            <h3>房间信息</h3>
            <table class="table">
                <tbody>
                    <tr>
                        <th>房号</th>
                        <td><%= room.room_number %></td>
                    </tr>
                    <tr>
                        <th>月租金</th>
                        <td>¥<%= room.monthly_rent.toFixed(2) %></td>
                    </tr>
                    <tr>
                        <th>税费单价</th>
                        <td><%= (room.tax_rate * 100).toFixed(2) %>%</td>
                    </tr>
                    <tr>
                        <th>电费单价</th>
                        <td>¥<%= room.electricity_rate.toFixed(2) %>/度</td>
                    </tr>
                    <tr>
                        <th>水费单价</th>
                        <td>¥<%= room.water_rate.toFixed(2) %>/吨</td>
                    </tr>
                </tbody>
            </table>

            <h3>修改房间信息</h3>
            <form id="updateRoomForm" class="form">
                <div class="form-group">
                    <label for="monthly_rent">月租金</label>
                    <input type="number" step="0.01" id="monthly_rent" name="monthly_rent" value="<%= room.monthly_rent %>" required>
                </div>
                <div class="form-group">
                    <label for="tax_rate">税费单价（每元租金的税费）</label>
                    <input type="number" step="0.0001" id="tax_rate" name="tax_rate" value="<%= room.tax_rate %>" required>
                </div>
                <div class="form-group">
                    <label for="electricity_rate">电费单价（元/度）</label>
                    <input type="number" step="0.0001" id="electricity_rate" name="electricity_rate" value="<%= room.electricity_rate %>" required>
                </div>
                <div class="form-group">
                    <label for="water_rate">水费单价（元/吨）</label>
                    <input type="number" step="0.0001" id="water_rate" name="water_rate" value="<%= room.water_rate %>" required>
                </div>
                <button type="submit" class="btn btn-primary">保存修改</button>
            </form>
        </div>

        <div class="readings">
            <h3>电表水表读数记录</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>日期</th>
                        <th>电表（度）</th>
                        <th>水表（吨）</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (readings && readings.length > 0) { %>
                        <% readings.forEach(reading => { %>
                            <tr>
                                <td><%= reading.reading_date %></td>
                                <td>
                                    电表: <%= reading.electricity_before %> → <%= reading.electricity_after %>
                                    (用电: <%= reading.electricity_after - reading.electricity_before %>)
                                </td>
                                <td>
                                    水表: <%= reading.water_before %> → <%= reading.water_after %>
                                    (用水: <%= reading.water_after - reading.water_before %>)
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" style="text-align: center;">暂无读数记录</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
