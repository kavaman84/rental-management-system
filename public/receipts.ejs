<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>收据管理 - 出租屋租赁管理系统</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>出租屋租赁管理系统</h1>
            <div class="user-info">
                <span>欢迎, <%= username %></span>
                <a href="/logout" class="btn btn-danger">退出</a>
            </div>
        </header>

        <div class="page-header">
            <h2>收据管理</h2>
            <a href="/dashboard" class="btn btn-secondary">返回首页</a>
        </div>

        <div class="generate-receipt">
            <h3>生成月收据</h3>
            <form id="generateReceiptForm" class="form">
                <div class="form-group">
                    <label for="room_id">选择房间</label>
                    <select id="room_id" name="room_id" required onchange="updateMeterReadings()">
                        <option value="">请选择房间</option>
                        <% rooms.forEach(room => { %>
                            <option value="<%= room.id %>"><%= room.room_number %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-group">
                    <label for="receipt_month">收据月份</label>
                    <input type="month" id="receipt_month" name="receipt_month" required>
                </div>
                <div class="form-group">
                    <label for="electricity_before">上月电表读数</label>
                    <input type="number" id="electricity_before" name="electricity_before" step="0.01" required>
                </div>
                <div class="form-group">
                    <label for="electricity_after">本月电表读数</label>
                    <input type="number" id="electricity_after" name="electricity_after" step="0.01" required>
                </div>
                <div class="form-group">
                    <label for="water_before">上月水表读数</label>
                    <input type="number" id="water_before" name="water_before" step="0.01" required>
                </div>
                <div class="form-group">
                    <label for="water_after">本月水表读数</label>
                    <input type="number" id="water_after" name="water_after" step="0.01" required>
                </div>
                <button type="submit" class="btn btn-primary">生成收据</button>
            </form>
        </div>

        <div class="receipts-list">
            <h3>收据列表</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>房号</th>
                        <th>月份</th>
                        <th>月租金</th>
                        <th>上月电表</th>
                        <th>本月电表</th>
                        <th>电费</th>
                        <th>上月水表</th>
                        <th>本月水表</th>
                        <th>水费</th>
                        <th>卫生费</th>
                        <th>网费</th>
                        <th>总金额</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (receipts && receipts.length > 0) { %>
                        <% receipts.forEach(receipt => { %>
                            <tr>
                                <td><%= receipt.room_number %></td>
                                <td><%= receipt.receipt_month %></td>
                                <td>¥<%= receipt.monthly_rent.toFixed(2) %></td>
                                <td><%= receipt.electricity_before ? receipt.electricity_before.toFixed(2) : '-' %></td>
                                <td><%= receipt.electricity_after ? receipt.electricity_after.toFixed(2) : '-' %></td>
                                <td>¥<%= receipt.electricity_amount.toFixed(2) %></td>
                                <td><%= receipt.water_before ? receipt.water_before.toFixed(2) : '-' %></td>
                                <td><%= receipt.water_after ? receipt.water_after.toFixed(2) : '-' %></td>
                                <td>¥<%= receipt.water_amount.toFixed(2) %></td>
                                <td>¥<%= receipt.housekeeping_fee ? receipt.housekeeping_fee.toFixed(2) : '0.00' %></td>
                                <td>¥<%= receipt.internet_fee ? receipt.internet_fee.toFixed(2) : '0.00' %></td>
                                <td class="total">¥<%= receipt.total_amount.toFixed(2) %></td>
                                <td>
                                    <span class="status <%= receipt.status %>">
                                        <%= receipt.status === 'paid' ? '已支付' : '未支付' %>
                                    </span>
                                </td>
                                <td>
                                    <button onclick="showEditReceiptModal(<%= receipt.id %>)" class="btn btn-small btn-warning">修改</button>
                                    <a href="/rooms/<%= receipt.room_id %>/receipts" class="btn btn-small btn-info">明细</a>
                                    <button onclick="deleteReceipt(<%= receipt.id %>)" class="btn btn-small btn-danger">删除</button>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="12" style="text-align: center;">暂无收据</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= currentPage - 1 %>" class="btn btn-small">上一页</a>
                    <% } %>

                    <span class="page-info">第 <%= currentPage %> 页 / 共 <%= totalPages %> 页</span>

                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %>" class="btn btn-small">下一页</a>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>

    <!-- 修改收据模态框 -->
    <div id="editReceiptModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeEditReceiptModal()">&times;</span>
            <h3>修改收据</h3>
            <form id="editReceiptForm" class="form">
                <input type="hidden" id="edit_receipt_id" name="edit_receipt_id">
                <div class="form-group">
                    <label for="edit_receipt_month">收据月份</label>
                    <input type="month" id="edit_receipt_month" name="edit_receipt_month" required>
                </div>
                <div class="form-group">
                    <label for="edit_electricity_before">上月电表读数</label>
                    <input type="number" step="0.01" id="edit_electricity_before" name="edit_electricity_before" required>
                </div>
                <div class="form-group">
                    <label for="edit_electricity_after">本月电表读数</label>
                    <input type="number" step="0.01" id="edit_electricity_after" name="edit_electricity_after" required>
                </div>
                <div class="form-group">
                    <label for="edit_water_before">上月水表读数</label>
                    <input type="number" step="0.01" id="edit_water_before" name="edit_water_before" required>
                </div>
                <div class="form-group">
                    <label for="edit_water_after">本月水表读数</label>
                    <input type="number" step="0.01" id="edit_water_after" name="edit_water_after" required>
                </div>
                <button type="submit" class="btn btn-primary">保存修改</button>
            </form>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
