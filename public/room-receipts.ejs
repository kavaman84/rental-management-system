<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>房间收据明细 - 出租屋租赁管理系统</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>出租屋租赁管理系统</h1>
            <div class="user-info">
                <span>欢迎, <%= username %></span>
                <a href="/logout" class="btn btn-danger">退出</a>
            </div>
        </header>

        <div class="page-header">
            <h2>房间收据明细 - <%= room.room_number %></h2>
            <a href="/rooms" class="btn btn-secondary">返回房间列表</a>
            <a href="/rooms/<%= room.id %>" class="btn btn-secondary">房间详情</a>
        </div>

        <div class="receipts-list">
            <h3>收据明细列表</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>月份</th>
                        <th>上月电表</th>
                        <th>本月电表</th>
                        <th>电费</th>
                        <th>上月水表</th>
                        <th>本月水表</th>
                        <th>水费</th>
                        <th>卫生费</th>
                        <th>网费</th>
                        <th>总金额</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (receipts && receipts.length > 0) { %>
                        <% receipts.forEach(receipt => { %>
                            <tr>
                                <td><%= receipt.receipt_month %></td>
                                <td><%= receipt.electricity_before ? receipt.electricity_before.toFixed(2) : '-' %></td>
                                <td><%= receipt.electricity_after ? receipt.electricity_after.toFixed(2) : '-' %></td>
                                <td>¥<%= receipt.electricity_amount.toFixed(2) %></td>
                                <td><%= receipt.water_before ? receipt.water_before.toFixed(2) : '-' %></td>
                                <td><%= receipt.water_after ? receipt.water_after.toFixed(2) : '-' %></td>
                                <td>¥<%= receipt.water_amount.toFixed(2) %></td>
                                <td>¥<%= receipt.housekeeping_fee ? receipt.housekeeping_fee.toFixed(2) : '0.00' %></td>
                                <td>¥<%= receipt.internet_fee ? receipt.internet_fee.toFixed(2) : '0.00' %></td>
                                <td class="total">¥<%= receipt.total_amount.toFixed(2) %></td>
                                <td>
                                    <span class="status <%= receipt.status %>">
                                        <%= receipt.status === 'paid' ? '已支付' : '未支付' %>
                                    </span>
                                </td>
                                <td>
                                    <% if (receipt.status === 'pending') { %>
                                        <button onclick="payReceipt(<%= receipt.id %>)" class="btn btn-small btn-success">支付</button>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="12" style="text-align: center;">暂无收据</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% if (currentPage > 1) { %>
                        <a href="?page=<%= currentPage - 1 %>" class="btn btn-small">上一页</a>
                    <% } %>

                    <span class="page-info">第 <%= currentPage %> 页 / 共 <%= totalPages %> 页</span>

                    <% if (currentPage < totalPages) { %>
                        <a href="?page=<%= currentPage + 1 %>" class="btn btn-small">下一页</a>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
